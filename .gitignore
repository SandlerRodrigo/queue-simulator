# -------------------------------------------------------------------------
# Rust/Cargo 
# -------------------------------------------------------------------------
# This single folder contains all your compiled binaries, object files, 
# and downloaded dependencies. Ignoring this replaces the need to ignore *.o
/target/

# Backup files generated if you use rustfmt (Rust's official code formatter)
**/*.rs.bk

# -------------------------------------------------------------------------
# Editor & OS specifics
# -------------------------------------------------------------------------
# Swap files generated by terminal text editors
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db